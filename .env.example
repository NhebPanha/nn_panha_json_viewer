# Nuxt Color Mode Default Preference
# Options: system, light, dark
NUXT_COLOR_MODE_PREFERENCE=system

# Development Port Configuration
PORT=3000

# Public site URL (used for canonical tags, sitemap, robots)
NUXT_PUBLIC_SITE_URL=https://json-model-generator.vercel.app

# Analytics (provider-agnostic — leave provider empty to disable)
# provider: plausible | google | umami
NUXT_PUBLIC_ANALYTICS_PROVIDER=
# GA measurement id (google) or website id (umami)
NUXT_PUBLIC_ANALYTICS_ID=
# Plausible domain, e.g. json-model-generator.vercel.app
NUXT_PUBLIC_ANALYTICS_DOMAIN=
# Self-hosted script origin for Plausible/Umami (optional)
NUXT_PUBLIC_ANALYTICS_HOST=
